;   param=value ; assign values to parameters

config_version=5

[application]

config/name="GMtk26"
run/main_scene="uid://crpq57gia7ovw"
config/features=PackedStringArray("4.7", "Forward Plus")
run/max_fps=120
config/icon="res://visual assets/icon.svg"
run/size/viewport_width=1024
run/size/viewport_height=512

[autoload]

GameSaver="*uid://cbn30uq2m8ghs"

[display]

window/size/viewport_width=384
window/size/viewport_height=216
window/size/window_width_override=1152
window/size/window_height_override=648
window/stretch/mode="viewport"

